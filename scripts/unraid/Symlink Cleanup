#!/bin/bash
# ======================================================================================
# SCRIPT: Symlink Sentinel (v1.0RC1)
# DESCRIPTION: Detects broken links, calculates library health, and repairs via Arrs.
# UPDATED: Added provider examples; Depth help comments; Version bump.
# ======================================================================================

# --- 1. MEDIA SERVER CONFIG ---
PLEX_URL="http://192.168.1.1:32400"
PLEX_TOKEN="ENTER_HERE"

EMBY_URL="http://192.168.1.1:8096"
EMBY_API="your_api_key_here"

# --- 2. PROVIDER DEFINITIONS ---
# To add a new provider (e.g., Radarr4K), define its URL and API key here.
# Ensure the prefix (e.g., RADARR4K) matches the Arr_Key used in the Library Mapping.

RADARR_URL="http://192.168.1.1:7878/radarr"
RADARR_API="your_api_key_here"

# Example for adding a second instance:
# RADARR4K_URL="http://192.168.1.1:7879/radarr4k"
# RADARR4K_API="your_api_key_here"

SONARR_URL="http://192.168.1.1:8989/sonarr"
SONARR_API="your_api_key_here"

LIDARR_URL="http://192.168.1.1:8686/lidarr"
LIDARR_API="your_api_key_here"

SPORTARR_URL="http://192.168.1.1:1867"
SPORTARR_API="your_api_key_here"

# --- 3. SAFETY & PACE CONFIGURATION ---
DRY_RUN_GLOBAL="N"               # [Y/N] Global safety switch
MAX_BROKEN_BEFORE_HALT=150       # CIRCUIT BREAKER: Halt if > X broken links found
ROLLING_24H_LIMIT=200            # FUEL GAUGE: Max deletions in 24 hours
UPTIME_MATURITY_REQUIRED=3600    # Wait for mount stability (seconds)
DELETES_PER_RUN=5                # Max deletions per script run

# --- 4. LIBRARY MAPPING ---
# Format: "Path | Name | Arr_Key | Mode | Notify_Type | Media_ID | Min_Depth | Max_Depth"
# 
# DEPTH GUIDE (TV Example: /tv/Show/Season/Episode.mkv):
# - Min_Depth 3: Starts looking at the 'Season' level.
# - Max_Depth 4: Stops at the 'Episode' file level. 
# This skips thousands of scans in the root 'tv' or 'Show' folders.
# Leave blank (||) for a full recursive scan (slower).

LIBRARIES=(
    "/mnt/computers/media/tv_hd|TV|SONARR|LIVE|PLEX|2|3|4"
    "/mnt/computers/media/movies_hd|Movies|RADARR|LIVE|PLEX|3|2|3"
    "/mnt/computers/media/tv_anime|TV - Anime|SONARR|LIVE|PLEX|13|3|4"
    "/mnt/computers/media/movies_anime|Movies - Anime|RADARR|LIVE|PLEX|21|2|3"
    "/mnt/computers/media/music|Music|LIDARR|LIVE|PLEX|14|3|4"
    "/mnt/computers/media/sport|Sport|SPORTARR|LIVE|PLEX|19||"
    # Example for 4K: "/mnt/computers/media/movies_4k|Movies 4K|RADARR4K|LIVE|PLEX|5|2|3"
)

# --- 5. PATHS & FILES ---
STATE_DB="/mnt/user/appdata/other/scripts/nzbdav/sentinel_state.db"
AUDIT_LOG="/mnt/user/appdata/other/scripts/nzbdav/sentinel_audit.log"
HOLD_FILE="/mnt/user/appdata/other/scripts/nzbdav/SENTINEL_HOLD.txt"
PRIME_STATE="/mnt/user/appdata/other/scripts/nzbdav/prime_state.db"
NZB_MOUNT="/mnt/computers/streaming/nzbdav"
DEC_MOUNT="/mnt/computers/streaming/decypharr"

# --------------------------------------------------------------------------------------
# 6. MAIN SCRIPT - DO NOT CHANGE BELOW HERE!!
# --------------------------------------------------------------------------------------

log_it() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"; }
touch "$STATE_DB"
[ ! -f "$AUDIT_LOG" ] && touch "$AUDIT_LOG"

echo "------------------------------------------------------------"
echo " SENTINEL CONFIGURATION"
echo "------------------------------------------------------------"
echo " Deletes Per Run:   $DELETES_PER_RUN"
echo " Circuit Breaker:   $MAX_BROKEN_BEFORE_HALT"
echo " Rolling 24h Limit: $ROLLING_24H_LIMIT"
echo "------------------------------------------------------------"

# 1. Maturity Check
if [ -f "$PRIME_STATE" ]; then
    NZB_START_TS=$(grep "NZB_START_TS" "$PRIME_STATE" | cut -d= -f2 | tr -d '"')
    if [ -n "$NZB_START_TS" ]; then
        UPTIME=$(( $(date +%s) - NZB_START_TS ))
        if [ "$UPTIME" -lt "$UPTIME_MATURITY_REQUIRED" ]; then
            log_it "STABILITY: Mount is fresh ($((UPTIME/60)) mins). Postponing."
            exit 0
        fi
    fi
fi

# 2. SCAN
TOTAL_BROKEN_GLOBAL=0
CANDIDATES=()

for ENTRY in "${LIBRARIES[@]}"; do
    IFS='|' read -r LIB_PATH LIB_NAME LIB_KEY LIB_MODE LIB_NOTIFY LIB_ID LIB_MIN LIB_MAX <<< "$ENTRY"
    if [ -d "$LIB_PATH" ]; then
        log_it ">> SCANNING: $LIB_NAME [$LIB_MODE]"
        
        DEPTH_ARGS=""
        [ -n "$LIB_MIN" ] && DEPTH_ARGS="$DEPTH_ARGS -mindepth $LIB_MIN"
        [ -n "$LIB_MAX" ] && DEPTH_ARGS="$DEPTH_ARGS -maxdepth $LIB_MAX"

        LIB_BROKEN_COUNT=0
        while IFS= read -r -d '' link; do
            CANDIDATES+=("$link|$LIB_NAME|$LIB_KEY|$LIB_MODE|$LIB_NOTIFY|$LIB_ID")
            ((LIB_BROKEN_COUNT++))
        done < <(find "$LIB_PATH" $DEPTH_ARGS -xtype l \( -lname "$NZB_MOUNT*" -o -lname "$DEC_MOUNT*" \) -print0 2>/dev/null)
        
        TOTAL_BROKEN_GLOBAL=$((TOTAL_BROKEN_GLOBAL + LIB_BROKEN_COUNT))
    fi
done

# 3. CIRCUIT BREAKER
if [ "$DRY_RUN_GLOBAL" = "N" ] && [ "$TOTAL_BROKEN_GLOBAL" -gt "$MAX_BROKEN_BEFORE_HALT" ]; then
    log_it "CRITICAL: Broken links ($TOTAL_BROKEN_GLOBAL) exceeds threshold ($MAX_BROKEN_BEFORE_HALT)."
    echo "$TOTAL_BROKEN_GLOBAL broken links found. Sentinel Locked." > "$HOLD_FILE"
    exit 1
fi

# 4. ROLLING 24H TALLY
NOW=$(date +%s)
VALID_ENTRIES=$(grep -E '^[0-9]+$' "$STATE_DB" | awk -v limit="$((NOW - 86400))" '$1 > limit')
echo "$VALID_ENTRIES" > "$STATE_DB"
ROLLING_COUNT=$(echo "$VALID_ENTRIES" | wc -w)

processed_this_run=0
declare -A LIB_SUMMARY

# 5. EXECUTION
for ENTRY in "${CANDIDATES[@]}"; do
    [ "$processed_this_run" -ge "$DELETES_PER_RUN" ] || [ "$ROLLING_COUNT" -ge "$ROLLING_24H_LIMIT" ] && break

    IFS='|' read -r LINK LIB_NAME LIB_KEY LIB_MODE LIB_NOTIFY LIB_ID <<< "$ENTRY"
    
    if [ "$LIB_MODE" = "LIVE" ] && [ "$DRY_RUN_GLOBAL" = "N" ]; then
        if rm -f "$LINK"; then
            # Notify Arr
            CMD_NAME="RescanSeries"; [[ "${LIB_KEY}" == *"RADARR"* ]] && CMD_NAME="RefreshMovie"
            URL_VAR="${LIB_KEY}_URL"; API_VAR="${LIB_KEY}_API"
            curl -s -X POST "${!URL_VAR}/api/v3/command" -H "X-Api-Key: ${!API_VAR}" -H "Content-Type: application/json" -d "{\"name\": \"$CMD_NAME\"}" > /dev/null
            
            # Notify Media Server
            if [ "$LIB_NOTIFY" = "PLEX" ] && [ -n "$LIB_ID" ]; then
                curl -s -G "${PLEX_URL}/library/sections/${LIB_ID}/refresh" -d "X-Plex-Token=${PLEX_TOKEN}" > /dev/null
            elif [ "$LIB_NOTIFY" = "EMBY" ]; then
                curl -s -X POST "${EMBY_URL}/Library/Refresh?api_key=${EMBY_API}" > /dev/null
            fi

            echo "$NOW" >> "$STATE_DB"
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] DELETED [$LIB_NAME]: $LINK" >> "$AUDIT_LOG"
            LIB_SUMMARY["$LIB_NAME"]=$(( ${LIB_SUMMARY["$LIB_NAME"]:-0} + 1 ))
            ((processed_this_run++))
            ((ROLLING_COUNT++))
        fi
    else
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] MOCK    [$LIB_NAME]: $LINK" >> "$AUDIT_LOG"
        LIB_SUMMARY["$LIB_NAME"]=$(( ${LIB_SUMMARY["$LIB_NAME"]:-0} + 1 ))
        ((processed_this_run++))
        ((ROLLING_COUNT++))
    fi
done

# 6. OUTPUT SUMMARY
echo "------------------------------------------------------------"
for LIB in "${!LIB_SUMMARY[@]}"; do
    log_it "[$LIB] Processed: ${LIB_SUMMARY[$LIB]}"
done

log_it "SENTINEL SUMMARY: Processed: $processed_this_run | 24h Tally: $ROLLING_COUNT"
log_it "Detailed paths recorded in $AUDIT_LOG"
echo "------------------------------------------------------------"
exit
