#!/bin/bash
# ======================================================================================
# SCRIPT: Plex Mount Monitor (DUMB Edition)
# VERSION: v1.0-DUMB
# DESCRIPTION: Stops binhex-plex when DUMB-2026's debrid mounts go down, and restarts
#              it once they recover. Runs every 2 minutes via cron.
#
# WHY THIS EXISTS: Plex caches stale FUSE handles after a mount drops — it cannot
# recover on its own and must be container-restarted to re-see the mounts. This script
# reacts faster (2 min) than the Heartbeat (5 min) without carrying its heavier
# priming/recovery workload. The two scripts are fully independent: if Heartbeat is
# mid-recovery, this script naturally sees mounts down → stops Plex → sees mounts up
# → starts Plex. No cross-script locking needed.
#
# BOTH MOUNTS GATE PLEX: Either RD (Decypharr) or NzbDAV going down stops Plex,
# since Plex libraries contain a mix of content from both mounts.
# ======================================================================================

# --------------------------------------------------------------------------------------
# 1. USER CONFIGURATION
# --------------------------------------------------------------------------------------

PLEX_CONTAINER="binhex-plex"
RD_MOUNT_PATH="/mnt/user/data/remote/decypharr/realdebrid/__all__"
NZB_MOUNT_PATH="/mnt/user/data/remote/nzbdav"
STATE_FILE="/mnt/user/appdata/other/scripts/dumb-2026/plex_mount_state"
LOG_FILE="/mnt/user/appdata/other/scripts/dumb-2026/plex_monitor.log"
BACKUP_PAUSE_FILE="${BACKUP_PAUSE_FILE:-/tmp/dumb-scripts.pause}"
BACKUP_PROC_PATTERN="${BACKUP_PROC_PATTERN:-(appdata\.backup|ca\.backup2).*backup\.(php|sh)}"
BACKUP_PAUSE_MAX_AGE_MIN="${BACKUP_PAUSE_MAX_AGE_MIN:-120}"

# --------------------------------------------------------------------------------------
# 2. MAIN SCRIPT
# --------------------------------------------------------------------------------------

mkdir -p "$(dirname "$LOG_FILE")"
mkdir -p "$(dirname "$STATE_FILE")"

log() {
    echo "[$(date "+%Y-%m-%d %H:%M:%S")] $1" | tee -a "$LOG_FILE"
}

_backup_in_progress() {
    if [ -f "$BACKUP_PAUSE_FILE" ]; then
        if find "$BACKUP_PAUSE_FILE" -mmin +"$BACKUP_PAUSE_MAX_AGE_MIN" 2>/dev/null | grep -q .; then
            rm -f "$BACKUP_PAUSE_FILE" 2>/dev/null || true  # stale — auto-clear
        else
            return 0  # fresh sentinel; backup is active
        fi
    fi
    pgrep -fq "$BACKUP_PROC_PATTERN" 2>/dev/null
}
if _backup_in_progress; then
    log "[PAUSED] appdata backup in progress — skipping run"
    exit 0
fi

notify() {
    /usr/local/emhttp/webGui/scripts/notify -e "DUMB Mount Monitor" -s "$1" -d "$2" -i "${3:-normal}" 2>/dev/null
}

is_mounted() {
    find "$1" -maxdepth 1 -mindepth 1 -print -quit 2>/dev/null | grep -q .
}

plex_running() {
    docker inspect -f '{{.State.Running}}' "$PLEX_CONTAINER" 2>/dev/null
}

# Check mounts
RD_UP=false
NZB_UP=false
is_mounted "$RD_MOUNT_PATH" && RD_UP=true
is_mounted "$NZB_MOUNT_PATH" && NZB_UP=true

# Both mounts must be up — either going down stops Plex
($RD_UP && $NZB_UP) && CURRENT="up" || CURRENT="down"
PREVIOUS=$(cat "$STATE_FILE" 2>/dev/null || echo "up")

log "RD: $RD_UP | NZB: $NZB_UP | State: $CURRENT (was: $PREVIOUS)"

if [ "$CURRENT" = "down" ] && [ "$PREVIOUS" = "up" ]; then
    log "Mounts down — stopping Plex"
    docker stop "$PLEX_CONTAINER" >> "$LOG_FILE" 2>&1
    notify "Plex Stopped" "Debrid mounts went down. RD: $RD_UP | NZB: $NZB_UP. Plex stopped." "alert"

elif [ "$CURRENT" = "down" ] && [ "$PREVIOUS" = "down" ]; then
    log "Mounts still down — keeping Plex stopped"
    if [ "$(plex_running)" = "true" ]; then
        log "Plex running but mounts down — stopping"
        docker stop "$PLEX_CONTAINER" >> "$LOG_FILE" 2>&1
    fi

elif [ "$CURRENT" = "up" ] && [ "$PREVIOUS" = "down" ]; then
    log "Mounts recovered — starting Plex"
    docker start "$PLEX_CONTAINER" >> "$LOG_FILE" 2>&1
    notify "Plex Restored" "Debrid mounts recovered. RD: $RD_UP | NZB: $NZB_UP. Plex started." "normal"

else
    log "Mounts healthy — RD: $RD_UP | NZB: $NZB_UP"
fi

echo "$CURRENT" > "$STATE_FILE"
