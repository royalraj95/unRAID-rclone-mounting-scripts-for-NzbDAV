#!/bin/bash
# ======================================================================================
# SCRIPT: Rclone Heartbeat & Intelligent Priming (DUMB Edition)
# VERSION: v1.0-DUMB-RC1
# DESCRIPTION: Monitors NzbDAV and Decypharr mounts exposed by DUMB-2026 via the
#              shared propagation bind (/mnt/debrid inside container →
#              /mnt/user/data/remote on host). Recovery restarts DUMB-2026.
#              No host-side rclone management — rclone lives inside the container.
# ======================================================================================

# --------------------------------------------------------------------------------------
# 1. USER CONFIGURATION
# --------------------------------------------------------------------------------------

# --- SCRIPT SETTINGS ---
SCRIPT_VERSION="v1.0-DUMB-RC1"
HARD_RESET="N"                      # Y = stop DUMB-2026, wipe rclone cache, exit. Restart manually after.
MAX_FAILURES="5"                    # Hard-reset auto-trigger after this many consecutive recovery failures
RECOVERY_COOLDOWN_SEC="900"         # Min seconds between Decypharr recovery / foundation restarts (3 heartbeat cycles)
PRIME_MAX_TIME="60"                 # Seconds to spend priming the dir-cache per run
STATE_FILE="/mnt/user/appdata/other/scripts/dumb-2026/prime_state.db"
LOG_FILE="/mnt/user/appdata/other/scripts/dumb-2026/heartbeat.log"

# --- MOUNT VALIDATION ---
# HOST-SIDE paths. NzbDAV is at the nzbdav/ dir directly; Decypharr's fuse.decypharr
# fs is mounted one level deeper at decypharr/realdebrid/ — NOT at decypharr/ itself.
NZB_MOUNT="/mnt/user/data/remote/nzbdav"
DEC_MOUNT="/mnt/user/data/remote/decypharr/realdebrid"
LOCAL_MEDIA_PATH="/mnt/user/data/media"

# rclone VFS cache is a host-side bind (/cache inside DUMB → this path on host).
# Used only when HARD_RESET=Y to wipe stale cache without docker exec.
RCLONE_CACHE_DIR="/mnt/cache_ssd/rclone-cache/cache"

# --- DOCKER SETTINGS ---
DUMB_CONTAINER="DUMB-2026"
ENABLERS="binhex-prowlarr"          # external indexer that feeds DUMB's internal *Arrs
CONSUMERS=""                         # empty: binhex *Arrs manage local libraries and don't consume DUMB's mounts;
                                     # DUMB's internal *Arrs go down/up with the container automatically

# --- EXCLUSION SETTINGS (subfolders under LOCAL_MEDIA_PATH to skip during priming) ---
# Skip local-only libraries (managed by the independent binhex stack, not DUMB).
EXCLUDE_DIRS="/books /downloads /tv /movies-hd /movies-uhd /movies-indian /Favorite-Scenes /music-videos"
EXCLUDE_EXTS=".srt .ass .vtt"

# --------------------------------------------------------------------------------------
# 2. MAIN SCRIPT
# --------------------------------------------------------------------------------------

log_step() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"; }

send_notification() {
    local subject="$1"
    local message="$2"
    local importance="$3"
    /usr/local/emhttp/webGui/scripts/notify -e "Rclone Heartbeat" -s "$subject" -d "$message" -i "$importance"
}

ALL_CONSUMERS="$CONSUMERS"

# --- SECTION 2.1: SUMMARY ---
log_step "VALIDATING: Script configuration and environment..."
echo "---------------------------------------------------"
echo "[CONFIG SUMMARY]"
echo "Script Version:      $SCRIPT_VERSION"
echo "State File:          $STATE_FILE"
echo "Hard Reset Toggle:   $HARD_RESET"
echo ""
echo "[MOUNT PATHS]"
echo "NzbDAV (host):       $NZB_MOUNT"
echo "Decypharr (host):    $DEC_MOUNT"
echo "Media Library:       $LOCAL_MEDIA_PATH"
echo ""
echo "[DOCKER SETTINGS]"
echo "Foundation:          $DUMB_CONTAINER"
echo "Enabler Containers:  $ENABLERS"
echo "Consumer Containers: $CONSUMERS"
echo "---------------------------------------------------"

# --- SECTION 2.2: ENVIRONMENTAL READINESS ---
if [[ "$HARD_RESET" == "N" ]]; then
    log_step "VERIFYING: System environment and load..."
    mkdir -p "$(dirname "$STATE_FILE")"
    mkdir -p "$(dirname "$LOG_FILE")"

    CURRENT_LOAD=$(awk '{print $1}' /proc/loadavg | cut -d. -f1)
    PATIENCE_MULT=1
    if [ "$CURRENT_LOAD" -gt 80 ]; then
        log_step "PATIENCE: High load detected ($CURRENT_LOAD). Doubling timeouts."
        PATIENCE_MULT=2
    fi
fi

# --- SECTION 2.3: FOUNDATION CHECK ---
[ -f "$STATE_FILE" ] && source "$STATE_FILE"
FOUNDATION_LAST_RESTART_TS=${FOUNDATION_LAST_RESTART_TS:-0}
FOUNDATION_RESTARTED=false

if [ "$(docker inspect -f '{{.State.Running}}' "$DUMB_CONTAINER" 2>/dev/null)" != "true" ]; then
    log_step "[!] $DUMB_CONTAINER is down. Starting..."
    docker start "$DUMB_CONTAINER" > /dev/null 2>&1
    FOUNDATION_RESTARTED=true
    FOUNDATION_LAST_RESTART_TS=$(date +%s)
fi

for container in $ENABLERS; do
    if [ "$(docker inspect -f '{{.State.Running}}' "$container" 2>/dev/null)" != "true" ]; then
        log_step "[!] $container is down. Starting..."
        docker start "$container" > /dev/null 2>&1
        FOUNDATION_RESTARTED=true
    fi
done

if [[ "$FOUNDATION_RESTARTED" == "true" ]]; then
    log_step "WAITING: Giving foundation containers 30s to initialize..."
    sleep 30
fi

# --- SECTION 2.4: INDEPENDENT MOUNT VALIDATION ---
N_CUR_FAIL=${N_FAIL_COUNT:-0}
D_CUR_FAIL=${D_FAIL_COUNT:-0}
DEC_LAST_RECOVERY_TS=${DEC_LAST_RECOVERY_TS:-0}
NZB_VALIDATION_SUBFOLDER="$NZB_MOUNT/completed-symlinks"

if [[ "$HARD_RESET" == "N" ]]; then
    # --- NzbDAV ---
    log_step "CHECKING: NzbDAV Mount integrity..."
    NZB_MOUNT_ALIVE=false

    if [ "$(docker inspect -f '{{.State.Running}}' "$DUMB_CONTAINER" 2>/dev/null)" == "true" ]; then
        N_COUNT=0
        while [ $N_COUNT -lt 5 ]; do
            if timeout $((5 * PATIENCE_MULT))s ls "$NZB_VALIDATION_SUBFOLDER" > /dev/null 2>&1; then
                NZB_MOUNT_ALIVE=true
                log_step "Passed: NzbDAV is UP."
                break
            fi
            log_step "WAITING: NzbDAV mount stalling (Attempt $((N_COUNT + 1))/5)..."
            sleep $((6 * PATIENCE_MULT))
            ((N_COUNT++))
        done
    else
        log_step "[!] $DUMB_CONTAINER is dead. Bypassing NzbDAV patience window..."
    fi

    if [[ "$NZB_MOUNT_ALIVE" == "true" ]]; then
        [[ "$NZB_STATE" != "UP" ]] && NZB_STATE="UP" && NZB_START_TS=$(date +%s)
        {
            echo "N_FAIL_COUNT=0"
            echo "D_FAIL_COUNT=$D_CUR_FAIL"
            echo "NZB_STATE=\"$NZB_STATE\""
            echo "NZB_START_TS=\"$NZB_START_TS\""
            echo "DEC_STATE=\"$DEC_STATE\""
            echo "DEC_START_TS=\"$DEC_START_TS\""
            echo "DEC_LAST_RECOVERY_TS=$DEC_LAST_RECOVERY_TS"
            echo "FOUNDATION_LAST_RESTART_TS=$FOUNDATION_LAST_RESTART_TS"
            echo "TOTAL_LMP_PRIMED=${TOTAL_LMP_PRIMED:-0}"
        } > "$STATE_FILE"
        N_CUR_FAIL=0
    else
        log_step "[!] Failed: NzbDAV is DOWN."
        send_notification "Mount Down" "NzbDAV mount integrity check failed at $NZB_MOUNT" "alert"
        [[ "$NZB_STATE" != "DOWN" ]] && NZB_STATE="DOWN" && NZB_START_TS=$(date +%s)
    fi

    # --- Decypharr (DFS via realdebrid subpath) ---
    if [[ -n "$DEC_MOUNT" ]]; then
        log_step "CHECKING: Decypharr Mount integrity..."
        DEC_MOUNT_ALIVE=false

        if [ "$(docker inspect -f '{{.State.Running}}' "$DUMB_CONTAINER" 2>/dev/null)" == "true" ]; then
            D_COUNT=0
            while [ $D_COUNT -lt 5 ]; do
                if { timeout $((5 * PATIENCE_MULT))s ls -d "$DEC_MOUNT/__all__" > /dev/null 2>&1 && \
                     timeout $((5 * PATIENCE_MULT))s ls "$DEC_MOUNT/version.txt" > /dev/null 2>&1; }; then
                    DEC_MOUNT_ALIVE=true
                    log_step "Passed: Decypharr is UP."
                    break
                fi
                log_step "WAITING: Decypharr mount not ready (Attempt $((D_COUNT + 1))/5)..."
                sleep $((6 * PATIENCE_MULT))
                ((D_COUNT++))
            done
        else
            log_step "[!] $DUMB_CONTAINER is dead. Bypassing Decypharr patience window..."
        fi

        if [[ "$DEC_MOUNT_ALIVE" == "false" ]]; then
            log_step "[!] Failed: Decypharr is DOWN."
            NOW_TS=$(date +%s)
            LAST_RESTART=$(( DEC_LAST_RECOVERY_TS > FOUNDATION_LAST_RESTART_TS ? DEC_LAST_RECOVERY_TS : FOUNDATION_LAST_RESTART_TS ))
            COOLDOWN_REMAINING=$(( RECOVERY_COOLDOWN_SEC - (NOW_TS - LAST_RESTART) ))

            if [[ "$LAST_RESTART" -gt 0 ]] && [[ "$COOLDOWN_REMAINING" -gt 0 ]]; then
                log_step "[!] COOLDOWN: Skipping Decypharr restart (${COOLDOWN_REMAINING}s remaining of ${RECOVERY_COOLDOWN_SEC}s window, fail count $D_CUR_FAIL/$MAX_FAILURES)."
            else
                log_step "Entering Recovery..."

                for container in $ALL_CONSUMERS; do
                    if [ "$(docker inspect -f '{{.State.Running}}' "$container" 2>/dev/null)" == "true" ]; then
                        log_step "Stopping Consumer: $container..."
                        docker stop "$container" > /dev/null 2>&1
                    fi
                done

                log_step "FIX: Restarting $DUMB_CONTAINER to recover Decypharr..."
                docker restart "$DUMB_CONTAINER" > /dev/null 2>&1
                DEC_START_TS=$(date +%s)
                DEC_LAST_RECOVERY_TS=$(date +%s)

                D_POST_COUNT=0
                while [ $D_POST_COUNT -lt 5 ]; do
                    sleep $((12 * PATIENCE_MULT))
                    if { timeout $((5 * PATIENCE_MULT))s ls -d "$DEC_MOUNT/__all__" > /dev/null 2>&1 && \
                         timeout $((5 * PATIENCE_MULT))s ls "$DEC_MOUNT/version.txt" > /dev/null 2>&1; }; then
                        DEC_MOUNT_ALIVE=true
                        log_step "RECOVERY: Decypharr is UP after restart."
                        break
                    fi
                    log_step "WAITING: Decypharr stabilizing after restart (Attempt $((D_POST_COUNT + 1))/5)..."
                    ((D_POST_COUNT++))
                done

                if [[ "$DEC_MOUNT_ALIVE" == "false" ]]; then
                    log_step "[!] CRITICAL: Decypharr recovery failed."
                    send_notification "Mount Down" "Decypharr recovery failed at $DEC_MOUNT." "alert"
                    D_CUR_FAIL=$((D_CUR_FAIL + 1))
                fi
            fi
        fi

        if [[ "$DEC_MOUNT_ALIVE" == "true" ]]; then
            if [[ "$DEC_STATE" != "UP" ]]; then DEC_STATE="UP"; DEC_START_TS=$(date +%s); fi
            D_CUR_FAIL=0
        else
            if [[ "$DEC_STATE" != "DOWN" ]]; then DEC_STATE="DOWN"; DEC_START_TS=$(date +%s); fi
        fi
    fi
else
    NZB_MOUNT_ALIVE=false
fi

# --- SECTION 3.1: MOUNT RECOVERY LOOP ---
RECOVERY_FAILED=false
if [[ "$HARD_RESET" == "N" ]] && [[ "$NZB_MOUNT_ALIVE" == "false" ]]; then
    log_step "REBUILD: Attempting mount recovery via container restart..."

    for container in $ALL_CONSUMERS; do
        if [ "$(docker inspect -f '{{.State.Running}}' "$container" 2>/dev/null)" == "true" ]; then
            log_step "Stopping Consumer: $container..."
            docker stop "$container" > /dev/null 2>&1
        fi
    done

    log_step "FIX: Restarting $DUMB_CONTAINER..."
    docker restart "$DUMB_CONTAINER" > /dev/null 2>&1
    FOUNDATION_LAST_RESTART_TS=$(date +%s)

    COUNT=0
    while [ $COUNT -lt 5 ]; do
        sleep $((12 * PATIENCE_MULT))
        if timeout $((5 * PATIENCE_MULT))s ls "$NZB_VALIDATION_SUBFOLDER" > /dev/null 2>&1; then
            log_step "SUCCESS: NzbDAV mount stabilized."
            send_notification "Mount Success" "NzbDAV mount has been successfully restored." "normal"
            NZB_STATE="UP"
            NZB_START_TS=$(date +%s)
            {
                echo "N_FAIL_COUNT=0"
                echo "D_FAIL_COUNT=$D_CUR_FAIL"
                echo "NZB_STATE=\"$NZB_STATE\""
                echo "NZB_START_TS=\"$NZB_START_TS\""
                echo "DEC_STATE=\"$DEC_STATE\""
                echo "DEC_START_TS=\"$DEC_START_TS\""
                echo "DEC_LAST_RECOVERY_TS=$DEC_LAST_RECOVERY_TS"
                echo "FOUNDATION_LAST_RESTART_TS=$FOUNDATION_LAST_RESTART_TS"
                echo "TOTAL_LMP_PRIMED=${TOTAL_LMP_PRIMED:-0}"
            } > "$STATE_FILE"
            NZB_MOUNT_ALIVE=true
            RECOVERY_FAILED=false
            break
        fi
        log_step "WAITING: Mount stabilizing (Attempt $((COUNT + 1))/5)..."
        ((COUNT++))
    done

    if [[ "$NZB_MOUNT_ALIVE" == "false" ]]; then
        RECOVERY_FAILED=true
        N_CUR_FAIL=$((N_CUR_FAIL + 1))
        {
            echo "N_FAIL_COUNT=$N_CUR_FAIL"
            echo "D_FAIL_COUNT=$D_CUR_FAIL"
            echo "NZB_STATE=\"$NZB_STATE\""
            echo "NZB_START_TS=\"$NZB_START_TS\""
            echo "DEC_STATE=\"$DEC_STATE\""
            echo "DEC_START_TS=\"$DEC_START_TS\""
            echo "DEC_LAST_RECOVERY_TS=$DEC_LAST_RECOVERY_TS"
            echo "FOUNDATION_LAST_RESTART_TS=$FOUNDATION_LAST_RESTART_TS"
            echo "TOTAL_LMP_PRIMED=${TOTAL_LMP_PRIMED:-0}"
        } > "$STATE_FILE"
    fi
fi

# --- SECTION 3.2: NUCLEAR JUNCTION ---
TRIGGER_HARD_RESET=false
if [[ "$HARD_RESET" == "Y" ]]; then
    log_step "MANUAL RESET: Executing requested purge..."
    TRIGGER_HARD_RESET=true
elif { [[ "$RECOVERY_FAILED" == "true" ]] && [[ "$N_CUR_FAIL" -ge "$MAX_FAILURES" ]]; } || [[ "$D_CUR_FAIL" -ge "$MAX_FAILURES" ]]; then
    log_step "[CRITICAL] Recovery failed and threshold ($MAX_FAILURES) reached. (NzbDAV=$N_CUR_FAIL Decypharr=$D_CUR_FAIL)"
    TRIGGER_HARD_RESET=true
fi

if [[ "$TRIGGER_HARD_RESET" == "true" ]]; then
    log_step "NUCLEAR OPTION: Stopping $DUMB_CONTAINER and resetting state..."
    send_notification "Forced Reset" "A forced reset has been triggered. Restarting DUMB-2026." "alert"

    for container in $ALL_CONSUMERS; do
        if [ "$(docker inspect -f '{{.State.Running}}' "$container" 2>/dev/null)" == "true" ]; then
            log_step "Stopping Consumer: $container..."
            docker stop "$container" > /dev/null 2>&1
        fi
    done

    log_step "Stopping $DUMB_CONTAINER..."
    docker stop "$DUMB_CONTAINER" > /dev/null 2>&1

    if [[ "$HARD_RESET" == "Y" ]] && [[ -d "$RCLONE_CACHE_DIR" ]]; then
        log_step "Wiping rclone VFS cache at $RCLONE_CACHE_DIR..."
        rm -rf "${RCLONE_CACHE_DIR:?}"/*
        log_step "SUCCESS: Cache wiped."
    fi

    sleep 5
    log_step "Starting $DUMB_CONTAINER..."
    docker start "$DUMB_CONTAINER" > /dev/null 2>&1

    NZB_STATE="DOWN"
    NZB_START_TS=$(date +%s)
    DEC_STATE="DOWN"
    DEC_START_TS=$(date +%s)
    {
        echo "N_FAIL_COUNT=0"
        echo "D_FAIL_COUNT=0"
        echo "NZB_STATE=\"$NZB_STATE\""
        echo "NZB_START_TS=\"$NZB_START_TS\""
        echo "DEC_STATE=\"$DEC_STATE\""
        echo "DEC_START_TS=\"$DEC_START_TS\""
        echo "DEC_LAST_RECOVERY_TS=0"
        echo "FOUNDATION_LAST_RESTART_TS=$(date +%s)"
        echo "TOTAL_LMP_PRIMED=0"
    } > "$STATE_FILE"
    log_step "SUCCESS: Nuclear Cleanup complete. Counter reset. EXITING."
    exit 0
fi

if [[ "$NZB_MOUNT_ALIVE" == "false" ]]; then
    log_step "[ABORT] Mount recovery failed. Threshold not yet reached ($N_CUR_FAIL/$MAX_FAILURES). Exiting."
    exit 1
fi

# --- SECTION 4: PRIMING & RESTORATION ---
log_step "INITIATING: Intelligent Priming (Library Only)..."

START_TIME=$(date +%s)
LAST_RUN_TS=${LAST_PRIMED_TS:-0}
LMP_RUN_COUNT=0
CUR_TOTAL_LMP=${TOTAL_LMP_PRIMED:-0}

log_step "Checking $LOCAL_MEDIA_PATH for new files..."
FIND_EXCLUDES=""
for d in $EXCLUDE_DIRS; do
    FIND_EXCLUDES="$FIND_EXCLUDES ! -path \"*/${d#/}/*\""
done
for e in $EXCLUDE_EXTS; do
    FIND_EXCLUDES="$FIND_EXCLUDES ! -name \"*$e\""
done

eval "nice -n 19 ionice -c 3 find \"$LOCAL_MEDIA_PATH\" -type l $FIND_EXCLUDES -newermt \"@$LAST_RUN_TS\" -exec ls -d {} + > /dev/null 2>&1"

if [[ "$ALL_HISTORICAL_PRIMED" != "TRUE" ]]; then
    log_step "Resuming historical prime for Media Path..."
    mapfile -t LMP_TARGETS < <(eval "nice -n 19 ionice -c 3 find \"$LOCAL_MEDIA_PATH\" -type l $FIND_EXCLUDES -not -newermt \"@${HISTORICAL_MARKER:-$(date +%s)}\" -printf \"%T@ %p\n\" | sort -rn | cut -d' ' -f2-")

    if [ ${#LMP_TARGETS[@]} -gt 0 ]; then
        for file in "${LMP_TARGETS[@]}"; do
            nice -n 19 ionice -c 3 ls -d "$file" > /dev/null 2>&1
            ((LMP_RUN_COUNT++))
            NEW_LMP_MARKER=$(stat -c %Y "$file" 2>/dev/null)
            [ $(( $(date +%s) - START_TIME )) -ge "$PRIME_MAX_TIME" ] && break
        done
    else
        ALL_HISTORICAL_PRIMED="TRUE"
    fi
fi
CUR_TOTAL_LMP=$((CUR_TOTAL_LMP + LMP_RUN_COUNT))
log_step "$LMP_RUN_COUNT new files found ... $CUR_TOTAL_LMP total files in the library."

{
    echo "N_FAIL_COUNT=${N_CUR_FAIL:-0}"
    echo "D_FAIL_COUNT=${D_CUR_FAIL:-0}"
    echo "LAST_PRIMED_TS=$(date +%s)"
    echo "HISTORICAL_MARKER=${NEW_LMP_MARKER:-$HISTORICAL_MARKER}"
    echo "ALL_HISTORICAL_PRIMED=$ALL_HISTORICAL_PRIMED"
    echo "NZB_STATE=\"$NZB_STATE\""
    echo "NZB_START_TS=\"$NZB_START_TS\""
    echo "DEC_STATE=\"$DEC_STATE\""
    echo "DEC_START_TS=\"$DEC_START_TS\""
    echo "DEC_LAST_RECOVERY_TS=${DEC_LAST_RECOVERY_TS:-0}"
    echo "FOUNDATION_LAST_RESTART_TS=${FOUNDATION_LAST_RESTART_TS:-0}"
    echo "TOTAL_LMP_PRIMED=$CUR_TOTAL_LMP"
} > "$STATE_FILE"

# --- SECTION 5: RESTORATION ---
log_step "RESTORATION: Starting Consumers..."
if [[ "$NZB_MOUNT_ALIVE" == "true" ]] && [[ "$DEC_MOUNT_ALIVE" == "true" ]]; then
    for container in $ALL_CONSUMERS; do
        docker start "$container" > /dev/null 2>&1
    done
else
    log_step "[ABORT] Restoration skipped. One or more mounts are offline."
fi

# --- SECTION 6: FINAL SUMMARY ---
log_step "FINALIZING: Generating environment report..."

CUR_LOAD=$(awk '{print $1}' /proc/loadavg)
RAM_TOTAL=$(grep MemTotal /proc/meminfo | awk '{print $2}')
RAM_FREE=$(grep MemAvailable /proc/meminfo | awk '{print $2}')
RAM_PERC=$(awk "BEGIN {printf \"%.1f\", ($RAM_FREE/$RAM_TOTAL)*100}")

calculate_duration() {
    local diff=$(($(date +%s) - $1))
    local days=$((diff / 86400))
    local hours=$(( (diff % 86400) / 3600 ))
    local mins=$(( (diff % 3600) / 60 ))
    [ $days -gt 0 ] && echo "${days}d ${hours}h ${mins}m" || ([ $hours -gt 0 ] && echo "${hours}h ${mins}m" || echo "${mins}m")
}

NZB_TIME=$(calculate_duration ${NZB_START_TS:-$(date +%s)})
DEC_TIME=$(calculate_duration ${DEC_START_TS:-$(date +%s)})

echo ""
echo "Status Summary:"
echo "NzbDAV ${NZB_STATE} (${NZB_TIME}) : Decypharr ${DEC_STATE} (${DEC_TIME}) | Primed ${TOTAL_LMP_PRIMED:-0} | Load ${CUR_LOAD} | RAM FREE: ${RAM_PERC}%"
echo "--------------------------------------------------------------------------------------"
log_step "STATUS: All Systems Operational."
exit 0
