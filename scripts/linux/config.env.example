# =====================================================================================
# DUMB scripts — Linux configuration (sourced by every script in scripts/linux/).
#
# Install location (default): /etc/dumb-scripts/config.env
# Override path via CONFIG_FILE=/somewhere/else.env before running a script.
#
# This file is sourced by lib/common.sh AND loaded by systemd as EnvironmentFile=.
# It must be valid for BOTH parsers:
#   - Bash: sources directly, supports quoting and ${...} expansion.
#   - systemd: treats spaces as ASSIGNMENT SEPARATORS — any value containing a space
#     MUST be double-quoted (e.g. EXCLUDE_DIRS="/books /tv"). No ${...} expansion.
# =====================================================================================

# === Foundation containers ===
DUMB_CONTAINER=DUMB-2026
PLEX_CONTAINER=binhex-plex
# Space-separated container names that should always be running.
ENABLERS=prowlarr
# Space-separated containers stopped/started during mount recovery.
# Leave empty unless you run *Arrs that consume the DUMB-managed mounts.
CONSUMERS=

# === Paths (host-side) ===
REMOTE_BIND=/srv/dumb/remote
MEDIA_ROOT=/srv/dumb/media
RCLONE_CACHE_DIR=/var/cache/rclone/cache
STATE_DIR=/var/lib/dumb-scripts
LOG_DIR=/var/log/dumb-scripts
# NZB_MOUNT and DEC_MOUNT are derived automatically from REMOTE_BIND by lib/common.sh.
# Override below ONLY if your DUMB container exposes them at non-standard subpaths.
# NOTE: systemd does not expand ${...}; write literal paths here, not ${REMOTE_BIND}/...
# NZB_MOUNT=/srv/dumb/remote/nzbdav
# DEC_MOUNT=/srv/dumb/remote/decypharr/realdebrid

# === Paths (container-side — what symlinks contain) ===
# /mnt/debrid is DUMB's default. Change only if your *Arr container binds the remote
# at a different path.
CONTAINER_REMOTE_PREFIX=/mnt/debrid

# === Heartbeat (mount-heartbeat.sh) ===
# Y wipes rclone VFS cache and restarts DUMB-2026 once, then resets to N.
HARD_RESET=N
MAX_FAILURES=5
PRIME_MAX_TIME=60
# Values contain spaces → MUST be double-quoted for systemd EnvironmentFile= compatibility.
EXCLUDE_DIRS="/books /downloads /tv /movies-hd /movies-uhd"
EXCLUDE_EXTS=".srt .ass .vtt"

# === Symlink Sentinel (symlink-cleanup.sh) ===
# START WITH Y. Flip to N after sentinel_audit.log shows correct MOCK entries.
DRY_RUN_GLOBAL=Y
MAX_BROKEN_BEFORE_HALT=150
ROLLING_24H_LIMIT=200
DELETES_PER_RUN=5
UPTIME_MATURITY_REQUIRED=3600
MIN_PACKS_SANITY=100
# Optional: external file with LIBRARIES entries (one per line).
# LIBRARIES_FILE=/etc/dumb-scripts/libraries.txt

# === Janitor (shutdown-janitor.sh) ===
PG_FLUSH_TIME=90
# Optional: semicolon-separated "source>dest" pairs to unmount before container teardown.
# Semicolon separates multiple pairs (systemd EnvironmentFile= doesn't support newlines in values).
# JANITOR_BINDS="/mnt/foo/sync>/var/lib/plex/transcode;/mnt/bar>/var/lib/plex/bar"

# === Plex ===
# Plex Settings → any item → Get Info → View XML; X-Plex-Token is in the URL.
PLEX_URL=
PLEX_TOKEN=

# === Emby (optional — leave blank to disable) ===
EMBY_URL=
EMBY_API=

# === DUMB internal *Arrs ===
# URLs are the host:port that DUMB exposes for each internal *Arr.
# API keys: each *Arr's WebUI → Settings → General → API Key.
SONARR_HD_URL=
SONARR_HD_API=
SONARR_4K_URL=
SONARR_4K_API=
RADARR_HD_URL=
RADARR_HD_API=
RADARR_4K_URL=
RADARR_4K_API=

# Disabled by default — set if you actually use these.
LIDARR_URL=
LIDARR_API=
SPORTARR_URL=
SPORTARR_API=

# === Appdata backup coordination ===
# Scripts skip their run while a backup is active, to avoid restarting a container the
# backup tool just stopped. Detected via this sentinel file OR a live backup process.
# Your backup tool's pre-run hook should `touch` this file; post-run hook should `rm -f` it.
BACKUP_PAUSE_FILE=/run/dumb-scripts.pause
# Matches both modern appdata.backup and legacy ca.backup2 Commander-Apps variants.
# VERIFY this matches your actual backup process: run `pgrep -af backup` during a live backup.
BACKUP_PROC_PATTERN="(appdata\.backup|ca\.backup2).*backup\.(php|sh)"
# Auto-expire a stale sentinel (post-run hook crash safety) after this many minutes.
BACKUP_PAUSE_MAX_AGE_MIN=120

# === Notifications ===
# NOTIFY_BACKEND: logger (default) | ntfy | apprise | discord
# See docs/notifications.md for details. Failures of any backend fall back to logger.
NOTIFY_BACKEND=logger
NTFY_URL=
APPRISE_URLS=
DISCORD_WEBHOOK_URL=
