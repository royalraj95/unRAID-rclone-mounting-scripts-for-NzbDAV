#!/bin/bash
# ======================================================================================
# SCRIPT: The Janitor (Array Shutdown Orchestrator) — DUMB Edition
# VERSION: v1.1-DUMB
# DESCRIPTION: Ensures a clean Unraid shutdown when running the DUMB-2026 stack.
#              Stops DUMB-2026 gracefully first (postgres flushes internally via SIGTERM
#              during the 90s grace window), then unmounts the shared debrid bind,
#              then stops all remaining containers.
#              No host-side rclone to kill, no ZFS pools to export.
# ======================================================================================

# --------------------------------------------------------------------------------------
# 1. USER CONFIGURATION
# --------------------------------------------------------------------------------------

# --- FOUNDATION CONTAINER ---
DUMB_CONTAINER="DUMB-2026"
PG_FLUSH_TIME="90"                  # Seconds to wait for DUMB to flush postgres before Docker hard-kills it

# --- MOUNT SETTINGS ---
# Host-side path of the shared bind (container /mnt/debrid ↔ host RSHARED_BIND).
RSHARED_BIND="/mnt/user/data/remote"

# LOCAL BIND BRIDGES (optional — uncomment and populate if Unraid won't release a
# bind-mount on its own, e.g. a Plex transcode sync bind)
declare -A BINDS
# BINDS=(
#     ["/mnt/user/data/media/plex/Sync+"]="/mnt/user/appdata/binhex-plex/transcode/Sync+"
# )

# --- SCRIPT SETTINGS ---
LOG_FILE="/mnt/user/appdata/other/scripts/dumb-2026/shutdown.log"
LOCK_DIR="/mnt/user/appdata/other/scripts/dumb-2026"

# --------------------------------------------------------------------------------------
# 2. MAIN SCRIPT
# --------------------------------------------------------------------------------------

mkdir -p "$(dirname "$LOG_FILE")"

log_step() {
    local MSG="$1"
    echo "[$(date '+%H:%M:%S')] INFO: $MSG" | tee -a "$LOG_FILE"
}

echo "--- COMMENCING CLEAN ARRAY SHUTDOWN (v1.1-DUMB) ---" | tee -a "$LOG_FILE"

# --- STAGE 1: PRE-SHUTDOWN RAM SYNC ---
log_step "FORCING RAM FLUSH: Writing active buffers to disk..."
sync
log_step "SUCCESS: RAM buffers committed to storage."

# --- STAGE 2: STOP DUMB-2026 FIRST ---
# Postgres lives inside DUMB-2026. A long stop timeout lets the container's entrypoint
# flush the DB cleanly before Docker sends SIGKILL.
if [ "$(docker inspect -f '{{.State.Running}}' "$DUMB_CONTAINER" 2>/dev/null)" == "true" ]; then
    log_step "Signaling $DUMB_CONTAINER to shut down (${PG_FLUSH_TIME}s grace for postgres flush)..."
    docker stop -t "$PG_FLUSH_TIME" "$DUMB_CONTAINER" > /dev/null 2>&1
    log_step "SUCCESS: $DUMB_CONTAINER stopped."
else
    log_step "INFO: $DUMB_CONTAINER was already stopped."
fi

# --- STAGE 3: BIND BRIDGES ---
if [ ${#BINDS[@]} -gt 0 ]; then
    log_step "Unmounting local bind bridges..."
    for dest in "${BINDS[@]}"; do
        if mountpoint -q "$dest"; then
            if umount -l "$dest" > /dev/null 2>&1; then
                log_step "SUCCESS: Unmounted bind bridge: $dest"
            else
                log_step "WARNING: Failed to unmount $dest (Device busy)"
            fi
        fi
    done
else
    log_step "INFO: No bind bridges configured. Skipping."
fi

# --- STAGE 4: STOP ALL REMAINING CONTAINERS ---
REMAINING=$(docker ps -q)
if [ -n "$REMAINING" ]; then
    log_step "Stopping all remaining Docker containers..."
    docker stop $REMAINING > /dev/null 2>&1
    log_step "SUCCESS: All remaining Docker containers stopped."
else
    log_step "INFO: No other containers running."
fi

# --- STAGE 5: UNMOUNT SHARED DEBRID BIND ---
# Once DUMB-2026 is stopped the fuse mounts collapse, but a lazy umount here
# ensures Unraid's array-stop logic doesn't stall on a stale mountpoint.
log_step "Releasing shared debrid bind at $RSHARED_BIND..."
if mountpoint -q "$RSHARED_BIND" 2>/dev/null; then
    umount -l "$RSHARED_BIND" > /dev/null 2>&1
    fusermount -uz "$RSHARED_BIND" > /dev/null 2>&1
    log_step "SUCCESS: Released $RSHARED_BIND."
else
    log_step "INFO: $RSHARED_BIND is not mounted. Skipping."
fi

# --- STAGE 6: CLEANUP & NOTIFY ---
log_step "Purging script lock files..."
rm -f "$LOCK_DIR"/janitor_*.lock
rm -f "$LOCK_DIR"/heartbeat_*.lock
log_step "SUCCESS: Lock files purged. Environment clear for shutdown."

/usr/local/emhttp/webGui/scripts/notify \
    -e "Server Status" \
    -s "Shutdown Prepared" \
    -d "v1.1-DUMB: DUMB-2026 stopped, debrid bind released, all containers clear." \
    -i "normal"

echo "--- JANITOR WORK COMPLETE ---" | tee -a "$LOG_FILE"
exit 0
