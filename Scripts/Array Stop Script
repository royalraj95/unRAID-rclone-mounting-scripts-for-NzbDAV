#!/bin/bash
# ======================================================================================
# SCRIPT: The Janitor (Array Shutdown Orchestrator)
# VERSION: v1.0
# DESCRIPTION: Ensures a clean Unraid shutdown by flushing databases, unmounting 
#              complex bind-mounts, terminating Rclone, and exporting ZFS pools.
# ======================================================================================

# --------------------------------------------------------------------------------------
# 1. USER CONFIGURATION
# --------------------------------------------------------------------------------------

# --- DATABASE SETTINGS ---
PG_CONTAINER="postgresql16" 
PG_FLUSH_TIME="60"

# --- MOUNT & BRIDGE SETTINGS ---
RC_PORT="5572"

CLOUD_MOUNTS=(
    "/mnt/computers/streaming/nzbdav"
    "/mnt/computers/streaming/decypharr"
)

# LOCAL BIND BRIDGES
# Fixed: Added explicit associative array declaration
declare -A BINDS
BINDS=(
    ["/mnt/computers/streaming/media/plex/Sync+"]="/mnt/cache/appdata/dockers/plex/Library/Application Support/Plex Media Server/Cache/Transcode/Sync+"
)

# ZFS POOLS TO EXPORT
ZFS_POOLS=("cache" "computers")

# --- SCRIPT SETTINGS ---
LOG_FILE="/mnt/cache/appdata/other/scripts/nzbdav/shutdown.log"
LOCK_DIR="/mnt/cache/appdata/other/scripts/nzbdav"

# --------------------------------------------------------------------------------------
# 2. MAIN SCRIPT
# --------------------------------------------------------------------------------------

mkdir -p "$(dirname "$LOG_FILE")"

log_step() { 
    local MSG="$1"
    echo "[$(date '+%H:%M:%S')] INFO: $MSG" | tee -a "$LOG_FILE"
}

echo "--- COMMENCING CLEAN ARRAY SHUTDOWN (v1.1) ---" | tee -a "$LOG_FILE"

# --- Stage 1. PRE-SHUTDOWN RAM SYNC ---
log_step "FORCING RAM FLUSH: Writing active buffers to disk..."
sync
log_step "SUCCESS: RAM buffers committed to storage."

# --- STAGE 2: STOP DOCKERS ---
if [ -n "$PG_CONTAINER" ]; then
    log_step "Signaling $PG_CONTAINER to flush and stop ($PG_FLUSH_TIME seconds)..."
    docker stop -t "$PG_FLUSH_TIME" "$PG_CONTAINER" > /dev/null 2>&1
    log_step "SUCCESS: Database flush and stop complete."
fi

log_step "Stopping all remaining containers..."
docker stop $(docker ps -q) > /dev/null 2>&1
log_step "SUCCESS: All remaining Docker containers stopped."

# --- STAGE 3: BIND BRIDGES ---
log_step "Unmounting local bind bridges..."
# Fixed: Quoted $dest to handle spaces in paths (like Plex Sync+)
for dest in "${BINDS[@]}"; do
    if mountpoint -q "$dest"; then
        if umount -l "$dest" > /dev/null 2>&1; then
            log_step "SUCCESS: Unmounted bind bridge: $dest"
        else
            log_step "WARNING: Failed to unmount $dest (Device busy)"
        fi
    fi
done

# --- STAGE 4: TERMINATE RCLONE ---
log_step "Terminating Rclone and clearing Port $RC_PORT..."
killall -9 rclone > /dev/null 2>&1
fuser -k "$RC_PORT/tcp" > /dev/null 2>&1

# --- STAGE 5: FORCE CLOUD UNMOUNTS ---
log_step "Forcing lazy unmount of cloud paths..."
for cloud_path in "${CLOUD_MOUNTS[@]}"; do
    umount -l "$cloud_path" > /dev/null 2>&1
    fusermount -uz "$cloud_path" > /dev/null 2>&1
    log_step "SUCCESS: Forced lazy unmount of cloud path: $cloud_path"
done

# --- STAGE 6: ZFS POOL EXPORT ---
if [ ${#ZFS_POOLS[@]} -gt 0 ]; then
    for pool in "${ZFS_POOLS[@]}"; do
        log_step "Exporting ZFS Pool: $pool..."
        if zpool export -f "$pool" > /dev/null 2>&1; then
            log_step "SUCCESS: ZFS Pool $pool exported."
        else
            log_step "CRITICAL: Pool $pool busy; manual intervention may be needed."
        fi
    done
fi

# --- STAGE 7: CLEANUP & NOTIFY ---
log_step "Purging script lock files..."
rm -f "$LOCK_DIR"/janitor_*.lock
rm -f "$LOCK_DIR"/heartbeat_*.lock "$LOCK_DIR"/prime_state.db
log_step "SUCCESS: Lock files purged. Environment clear for shutdown."

/usr/local/emhttp/webGui/scripts/notify \
    -e "Server Status" \
    -s "Shutdown Prepared" \
    -d "v1.1 Binds, Bridges, and ZFS Pools cleared cleanly." \
    -i "normal"

echo "--- JANITOR WORK COMPLETE ---" | tee -a "$LOG_FILE"
exit 0
